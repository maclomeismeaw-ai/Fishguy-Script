local player = game:GetService("Players").LocalPlayer

while true do
    local portal = workspace.Illusion.LegacyPortal:WaitForChild("STGardenPortal")

    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    hrp.CFrame = portal:GetPivot() + Vector3.new(0, 3, 0)

    task.wait(2)

    local button = player.PlayerGui.Teleports["Lobby -> Legacy"].Teleport.Button

    for _,v in pairs(getconnections(button.Activated)) do
        v:Fire()
    end

    task.wait(10)
end

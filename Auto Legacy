local Players = game:GetService("Players")
local player = Players.LocalPlayer

if not game:IsLoaded() then
    game.Loaded:Wait()
end

local function getCharacter()
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    return char, hrp
end

while true do
    local illusion = workspace:WaitForChild("Illusion")
    local legacyPortal = illusion:WaitForChild("LegacyPortal")
    local portal = legacyPortal:WaitForChild("STGardenPortal")

    local _, hrp = getCharacter()

    hrp.CFrame = portal:GetPivot() + Vector3.new(0, 3, 0)

    task.wait(2)

    local playerGui = player:WaitForChild("PlayerGui")
    local teleports = playerGui:WaitForChild("Teleports")
    local lobbyTeleport = teleports:WaitForChild("Lobby -> Legacy")
    local button = lobbyTeleport:WaitForChild("Teleport"):WaitForChild("Button")

    for _, v in pairs(getconnections(button.Activated)) do
        v:Fire()
    end

    task.wait(5)
end
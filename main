repeat task.wait() until game:IsLoaded()

local Method = _G.FarmMethod or "Ninja"

task.spawn(function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/maclomeismeaw-ai/Fishguy-Script/main/Ui"))()
end)

task.spawn(function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/maclomeismeaw-ai/Fishguy-Script/main/Auto%20Legacy"))()
end)

if Method == "Ninja" then

    task.spawn(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/maclomeismeaw-ai/Fishguy-Script/main/Auto%20farm%20%28Ninja%20Method%29"))()
    end)

    task.spawn(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/maclomeismeaw-ai/Fishguy-Script/main/Auto%20skip"))()
    end)

elseif Method == "Camera" then

    task.spawn(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/maclomeismeaw-ai/Fishguy-Script/main/Auto%20farm%20%28Camera%20Spider%20Method%29"))()
    end)

    task.spawn(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/maclomeismeaw-ai/Fishguy-Script/main/Auto%20skip"))()
    end)

elseif Method == "Insane" then

    task.spawn(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/maclomeismeaw-ai/Fishguy-Script/main/Auto%20farm%20%28Insane%29"))()
    end)

    task.spawn(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/maclomeismeaw-ai/Fishguy-Script/main/Auto%20skip%20%28Insane%29"))()
    end)

end

task.spawn(function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/maclomeismeaw-ai/Fishguy-Script/main/Tp"))()
end)

task.spawn(function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/maclomeismeaw-ai/Fishguy-Script/main/Webhook"))()
end)
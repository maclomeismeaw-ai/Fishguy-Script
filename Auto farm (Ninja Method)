local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local money = player:WaitForChild("leaderstats"):WaitForChild("Money")
local troops = workspace:WaitForChild("Troops")
local currentWave = RS:WaitForChild("MatchData"):WaitForChild("CurrentWave")
local remote = RS.NetworkingContainer.DataRemote

local NINJA_PLACE = 200
local NINJA_UPGRADES = {200,300,400,600}

local HELI_PLACE = 200
local HELI_UPGRADES = {300,500,800,1500}

repeat
	task.wait()
until currentWave.Value == 1

task.wait(1)

local function waitMoney(amount)
	while money.Value < amount do
		money:GetPropertyChangedSignal("Value"):Wait()
	end
end

local function countUnits(name)
	local total = 0

	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == name then
			total += 1
		end
	end

	return total
end

local function updateValues(unitName)
	local index = 0

	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == unitName then
			index += 1

			local val = v:FindFirstChild("Value") or Instance.new("IntValue")
			val.Name = "Value"
			val.Value = index
			val.Parent = v
		end
	end
end

local function getUnitByValue(unitName,num)
	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == unitName then
			local val = v:FindFirstChild("Value")

			if val and val.Value == num then
				return v
			end
		end
	end
end

local function getLatestUnit(unitName)
	updateValues(unitName)

	local highest = 0
	local found = nil

	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == unitName then
			local val = v:FindFirstChild("Value")

			if val and val.Value > highest then
				highest = val.Value
				found = v
			end
		end
	end

	return found
end

local function placeUnit(unitName,pos,slot,cost)
	while true do
		waitMoney(cost)

		local before = countUnits(unitName)

		local args = {
			[1] = {
				[1] = {
					[1] = "\226\129\130\22",
					[2] = unitName,
					[3] = pos,
					[4] = slot
				}
			}
		}

		remote:FireServer(unpack(args))

		local start = tick()

		repeat
			task.wait(0.3)

			if countUnits(unitName) > before then
				task.wait(0.5)
				return getLatestUnit(unitName)
			end

		until tick() - start >= 3
	end
end

local function upgrade(unit)
	if not unit then return end

	local args = {
		[1] = {
			[1] = {
				[1] = "\226\129\130#",
				[2] = unit
			}
		}
	}

	remote:FireServer(unpack(args))
	task.wait(1)
end

local function maxUpgrade(unit,costs)
	if not unit then return end

	for _,cost in ipairs(costs) do
		waitMoney(cost)
		upgrade(unit)
	end
end

local ninjaCount = 0

local function placeAndMaxNinja(pos)
	local ninja = placeUnit("NinjaCameraman",pos,1,NINJA_PLACE)

	ninjaCount += 1

	updateValues("NinjaCameraman")

	ninja = getUnitByValue("NinjaCameraman",ninjaCount)

	if not ninja then
		ninja = getLatestUnit("NinjaCameraman")
	end

	maxUpgrade(ninja,NINJA_UPGRADES)
end

local function placeAndMaxHeli(pos)
	local heli = placeUnit("CameraHelicopter",pos,5,HELI_PLACE)

	heli = getLatestUnit("CameraHelicopter")

	maxUpgrade(heli,HELI_UPGRADES)
end


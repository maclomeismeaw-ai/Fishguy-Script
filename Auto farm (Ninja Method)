local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local money = player:WaitForChild("leaderstats"):WaitForChild("Money")
local troops = workspace:WaitForChild("Troops")

local NINJA_PLACE = 200
local NINJA_UPGRADES = {200,300,400,600}

local HELI_PLACE = 200
local HELI_UPGRADES = {300,500,800,1500}

local function waitMoney(amount)
    while money.Value < amount do
        money:GetPropertyChangedSignal("Value"):Wait()
    end
    task.wait(1)
end

local function place(unitName, position, slot)
    local args = {
        [1] = {
            [1] = {
                [1] = "\226\129\130\22",
                [2] = unitName,
                [3] = position,
                [4] = slot
            }
        }
    }

    RS.NetworkingContainer.DataRemote:FireServer(unpack(args))

    task.wait(1)
end

local function upgrade(unit)
    if not unit then
        return
    end

    local args = {
        [1] = {
            [1] = {
                [1] = "\226\129\130#",
                [2] = unit
            }
        }
    }

    RS.NetworkingContainer.DataRemote:FireServer(unpack(args))

    task.wait(1)
end

local function updateValues(unitName)
    local index = 0

    for _, v in ipairs(troops:GetChildren()) do
        if v.Name == unitName then
            index += 1

            local val = v:FindFirstChild("Value") or Instance.new("IntValue")

            val.Name = "Value"
            val.Parent = v
            val.Value = index
        end
    end
end

local function getUnitByValue(unitName, num)
    for _, v in ipairs(troops:GetChildren()) do
        if v.Name == unitName then
            local val = v:FindFirstChild("Value")

            if val and val.Value == num then
                return v
            end
        end
    end
end

local ninjaValue = 0

local function placeAndMaxNinja(position)
    waitMoney(NINJA_PLACE)

    place("NinjaCameraman", position, 1)

    updateValues("NinjaCameraman")

    task.wait(1)

    ninjaValue += 1

    local ninja = getUnitByValue("NinjaCameraman", ninjaValue)

    if not ninja then
        return
    end

    for _, cost in ipairs(NINJA_UPGRADES) do
        waitMoney(cost)

        local target = getUnitByValue("NinjaCameraman", ninjaValue)

        if target then
            upgrade(target)
        end
    end
end

local lane1 = Vector3.new(-69.5605, 2.2020, 55.6358)
local lane2 = lane1 + Vector3.new(5,0,0)

local offsetZ = 5

placeAndMaxNinja(lane1)
placeAndMaxNinja(lane2)

for round = 1, 5 do
    lane1 = lane1 + Vector3.new(0,0,offsetZ)
    placeAndMaxNinja(lane1)

    lane2 = lane2 + Vector3.new(0,0,offsetZ)
    placeAndMaxNinja(lane2)
end

lane1 = lane1 + Vector3.new(0,0,offsetZ)

placeAndMaxNinja(lane1)

local heliValue = 0

local function placeAndMaxHeli(position)
    waitMoney(HELI_PLACE)

    place("CameraHelicopter", position, 5)

    updateValues("CameraHelicopter")

    task.wait(1)

    heliValue += 1

    local heli = getUnitByValue("CameraHelicopter", heliValue)

    if not heli then
        return
    end

    for _, cost in ipairs(HELI_UPGRADES) do
        waitMoney(cost)

        local target = getUnitByValue("CameraHelicopter", heliValue)

        if target then
            upgrade(target)
        end
    end
end


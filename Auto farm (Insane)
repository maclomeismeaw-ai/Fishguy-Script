local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local money = player:WaitForChild("leaderstats"):WaitForChild("Money")
local troops = workspace:WaitForChild("Troops")
local remote = RS.NetworkingContainer.DataRemote
local currentWave = RS:WaitForChild("MatchData"):WaitForChild("CurrentWave")

local SCIENTIST_PLACE = 100
local SCIENTIST_UPGRADES = {300,600}

local NINJA_PLACE = 200
local NINJA_UPGRADES = {200,300,400}

local MECH_PLACE = 400
local MECH_UPGRADES = {300,500,800,1000}

local SPIDER_PLACE = 300
local SPIDER_UPGRADES = {800,1500,3000,5000}

repeat task.wait() until currentWave.Value == 1
task.wait(1)

local function waitMoney(amount)
	while money.Value < amount do
		money:GetPropertyChangedSignal("Value"):Wait()
	end
	task.wait(0.2)
end

local function countUnits(name)
	local total = 0
	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == name then
			total += 1
		end
	end
	return total
end

local function updateValues(unitName)
	local index = 0

	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == unitName then
			index += 1

			local val = v:FindFirstChild("Value")
			if not val then
				val = Instance.new("IntValue")
				val.Name = "Value"
				val.Parent = v
			end

			val.Value = index
		end
	end
end

local function getByValue(unitName,num)
	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == unitName then
			local val = v:FindFirstChild("Value")
			if val and val.Value == num then
				return v
			end
		end
	end
end

local function getLatest(unitName)
	updateValues(unitName)

	local highest = 0
	local found = nil

	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == unitName then
			local val = v:FindFirstChild("Value")
			if val and val.Value > highest then
				highest = val.Value
				found = v
			end
		end
	end

	return found
end

local function placeRaw(unitName,pos,slot)
	local args = {
		[1] = {
			[1] = {
				[1] = "\226\129\130\22",
				[2] = unitName,
				[3] = pos,
				[4] = slot
			}
		}
	}

	remote:FireServer(unpack(args))
end

local function upgrade(unit)
	if not unit or not unit.Parent then return end

	local args = {
		[1] = {
			[1] = {
				[1] = "\226\129\130#",
				[2] = unit
			}
		}
	}

	remote:FireServer(unpack(args))
	task.wait(1)
end

local function sell(unit)
	if not unit or not unit.Parent then return end

	local args = {
		[1] = {
			[1] = {
				[1] = "\226\129\130$",
				[2] = unit
			}
		}
	}

	remote:FireServer(unpack(args))
	task.wait(1)
end

local function forcePlace(unitName,pos,slot,cost,maxTry)
	maxTry = maxTry or 30

	for _ = 1,maxTry do
		waitMoney(cost)

		local before = countUnits(unitName)

		placeRaw(unitName,pos,slot)

		local t = tick()

		repeat
			task.wait(0.25)

			if countUnits(unitName) > before then
				task.wait(0.5)
				return getLatest(unitName)
			end

		until tick() - t >= 3
	end

	return nil
end

local function maxUpgrade(unit,costs)
	if not unit then return end

	for _,cost in ipairs(costs) do
		waitMoney(cost)

		if unit and unit.Parent then
			upgrade(unit)
		else
			return
		end
	end
end

local function placeScientist(pos)
	local u = forcePlace("ScientistCameraman",pos,1,SCIENTIST_PLACE)
	return u
end

local function placeNinja(pos)
	local u = forcePlace("NinjaCameraman",pos,1,NINJA_PLACE)
	if not u then return end

	waitMoney(NINJA_UPGRADES[1]) upgrade(u)
	waitMoney(NINJA_UPGRADES[2]) upgrade(u)

	return u
end

local function placeMech(pos)
	local u = forcePlace("MechCameraman",pos,1,MECH_PLACE)
	maxUpgrade(u,MECH_UPGRADES)
	return u
end

local function placeSpider(pos)
	local u = forcePlace("CameraSpider",pos,1,SPIDER_PLACE)
	maxUpgrade(u,SPIDER_UPGRADES)
	return u
end


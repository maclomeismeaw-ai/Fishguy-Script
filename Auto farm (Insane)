local spiderCount = 0
local scientistSellIndex = 1

local function spawnSpider(position)
	spiderCount += 1

	if spiderCount == 8 then
		local ninjaUnit = troops:FindFirstChild("NinjaCameraman")
		if ninjaUnit then
			sell(ninjaUnit)
		end
	end

	if spiderCount >= 9 and spiderCount <= 12 then
		local target = scientists[scientistSellIndex]

		if target and target.Parent then
			sell(target)
		end

		scientistSellIndex += 1
	end

	placeAndMaxSpider(position)
end


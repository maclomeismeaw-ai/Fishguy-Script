local row3 = spiderStart + Vector3.new(-8,0,0)

local spiderCount = 0
local scientistSellIndex = 1

local function spawnSpider(pos)
	spiderCount += 1

	if spiderCount == 8 and ninja then
		sell(ninja)
	end

	if spiderCount >= 9 and spiderCount <= 12 then
		local target = scientists[scientistSellIndex]
		if target then
			sell(target)
		end
		scientistSellIndex += 1
	end

	placeSpider(pos)
end


local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local money = player:WaitForChild("leaderstats"):WaitForChild("Money")
local troops = workspace:WaitForChild("Troops")

local SCIENTIST_PLACE = 100
local SCIENTIST_UPGRADES = {300,600}

local NINJA_PLACE = 200
local NINJA_UPGRADES = {200,300,400}

local MECH_PLACE = 400
local MECH_UPGRADES = {300,500,800,1000}

local SPIDER_PLACE = 300
local SPIDER_UPGRADES = {800,1500,3000,5000}

local function waitMoney(amount)
	while money.Value < amount do
		money:GetPropertyChangedSignal("Value"):Wait()
	end
	task.wait(1)
end

local function place(unitName, position, slot)
	local args = {
		[1] = {
			[1] = {
				[1] = "\226\129\130\22",
				[2] = unitName,
				[3] = position,
				[4] = slot
			}
		}
	}

	RS.NetworkingContainer.DataRemote:FireServer(unpack(args))
	task.wait(1)
end

local function upgrade(unit)
	if not unit then return end

	local args = {
		[1] = {
			[1] = {
				[1] = "\226\129\130#",
				[2] = unit
			}
		}
	}

	RS.NetworkingContainer.DataRemote:FireServer(unpack(args))
	task.wait(1)
end

local function sell(unit)
	if not unit then return end

	local args = {
		[1] = {
			[1] = {
				[1] = "\226\129\130$",
				[2] = unit
			}
		}
	}

	RS.NetworkingContainer.DataRemote:FireServer(unpack(args))
	task.wait(1)
end

local function placeCheck(unitName, position, slot)
	local before = 0

	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == unitName then
			before += 1
		end
	end

	place(unitName, position, slot)

	task.wait(1)

	local after = 0

	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == unitName then
			after += 1
		end
	end

	return after > before
end

local function forcePlace(unitName, position, slot)
	repeat
		task.wait(0.5)
	until placeCheck(unitName, position, slot)
end

local function updateValues(unitName)
	local index = 0

	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == unitName then
			index += 1

			local val = v:FindFirstChild("Value") or Instance.new("IntValue")
			val.Name = "Value"
			val.Parent = v
			val.Value = index
		end
	end
end

local function getLatest(unitName)
	local latest = nil
	local highest = 0

	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == unitName then
			local val = v:FindFirstChild("Value")

			if val and val.Value > highest then
				highest = val.Value
				latest = v
			end
		end
	end

	return latest
end

local function placeScientist(position)
	waitMoney(SCIENTIST_PLACE)
	forcePlace("ScientistCameraman", position, 1)
	updateValues("ScientistCameraman")
	task.wait(1)
	return getLatest("ScientistCameraman")
end

local function placeMech(position)
	waitMoney(MECH_PLACE)
	forcePlace("MechCameraman", position, 1)
	updateValues("MechCameraman")
	task.wait(1)
	return getLatest("MechCameraman")
end

local function placeAndMaxNinja(position)
	waitMoney(NINJA_PLACE)
	forcePlace("NinjaCameraman", position, 1)
	updateValues("NinjaCameraman")
	task.wait(1)

	local ninja = getLatest("NinjaCameraman")
	if not ninja then return end

	for i = 1,2 do
		waitMoney(NINJA_UPGRADES[i])
		if ninja and ninja.Parent then
			upgrade(ninja)
		end
	end

	return ninja
end

local function placeAndMaxMech(position)
	local mech = placeMech(position)
	if not mech then return end

	for _,cost in ipairs(MECH_UPGRADES) do
		waitMoney(cost)
		if mech and mech.Parent then
			upgrade(mech)
		end
	end
end

local function placeAndMaxSpider(position)
	waitMoney(SPIDER_PLACE)
	forcePlace("CameraSpider", position, 1)
	updateValues("CameraSpider")
	task.wait(1)

	local spider = getLatest("CameraSpider")
	if not spider then return end

	for _,cost in ipairs(SPIDER_UPGRADES) do
		waitMoney(cost)
		if spider and spider.Parent then
			upgrade(spider)
		end
	end
end


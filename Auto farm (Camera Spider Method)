task.wait(1)

local basePos = Vector3.new(-70.5,2.16,55.3)

place("CameraSpider",basePos,1,300)
updateValues()

task.wait(1)

local cam1 = getCameraByValue(1)
local cam2 = getCameraByValue(2)

upgradeToLevel(cam2,5,costs)
upgradeToLevel(cam1,5,costs)

local offsetZ = 5

while true do
    basePos += Vector3.new(0,0,offsetZ)

    place("CameraSpider",basePos,1,300)
    updateValues()

    task.wait(1)

    local latest = getLatestSpider()

    if not latest then
        break
    end

    upgradeToLevel(latest,5,costs)

    task.wait(1)
end
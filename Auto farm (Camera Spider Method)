local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local money = player:WaitForChild("leaderstats"):WaitForChild("Money")
local troops = workspace:WaitForChild("Troops")
local remote = RS.NetworkingContainer.DataRemote
local currentWave = RS:WaitForChild("MatchData"):WaitForChild("CurrentWave")

local costs = {800,1500,3000,5000}

repeat
	task.wait()
until currentWave.Value == 1

task.wait(1)

local function waitMoney(amount)
	while money.Value < amount do
		money:GetPropertyChangedSignal("Value"):Wait()
	end
end

local function countUnits(name)
	local total = 0

	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == name then
			total += 1
		end
	end

	return total
end

local function updateValues()
	local index = 0

	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == "CameraSpider" then
			index += 1

			local val = v:FindFirstChild("Value") or Instance.new("IntValue")
			val.Name = "Value"
			val.Value = index
			val.Parent = v
		end
	end
end

local function getCameraByValue(num)
	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == "CameraSpider" then
			local val = v:FindFirstChild("Value")

			if val and val.Value == num then
				return v
			end
		end
	end
end

local function getLatestSpider()
	updateValues()

	local highest = 0
	local found = nil

	for _,v in ipairs(troops:GetChildren()) do
		if v.Name == "CameraSpider" then
			local val = v:FindFirstChild("Value")

			if val and val.Value > highest then
				highest = val.Value
				found = v
			end
		end
	end

	return found
end

local function place(unitName,position,slot,cost)
	while true do
		waitMoney(cost)

		local before = countUnits(unitName)

		local args = {
			[1] = {
				[1] = {
					[1] = "\226\129\130\22",
					[2] = unitName,
					[3] = position,
					[4] = slot
				}
			}
		}

		remote:FireServer(unpack(args))

		local start = tick()

		repeat
			task.wait(0.3)

			if countUnits(unitName) > before then
				task.wait(0.5)
				return true
			end

		until tick() - start >= 3
	end
end

local function upgrade(unit)
	if not unit then return end

	local args = {
		[1] = {
			[1] = {
				[1] = "\226\129\130#",
				[2] = unit
			}
		}
	}

	remote:FireServer(unpack(args))
	task.wait(1)
end

local function maxUpgrade(unit,costTable)
	if not unit then return end

	for _,cost in ipairs(costTable) do
		waitMoney(cost)
		upgrade(unit)
	end
end

place("CameraSpider",Vector3.new(-57.5,2.16,10.05),1,300)
updateValues()

task.wait(1)

local pos = Vector3.new(-66.5,2.20,33.05)
local placed = 0

while placed < 4 do
	if place("ScientistCameraman",pos,1,100) then
		pos += Vector3.new(0,0,2)
		placed += 1
	end

	task.wait(0.5)
end

task.wait(1)

local basePos = Vector3.new(-70.5,2.16,55.3)

place("CameraSpider",basePos,1,300)
updateValues()

task.wait(1)

local cam1 = getCameraByValue(1)
local cam2 = getCameraByValue(2)

maxUpgrade(cam2,costs)
maxUpgrade(cam1,costs)

local offsetZ = 5

while true do
	basePos += Vector3.new(0,0,offsetZ)

	place("CameraSpider",basePos,1,300)
	updateValues()

	task.wait(1)

	local latest = getLatestSpider()

	if not latest then
		break
	end

	maxUpgrade(latest,costs)

	task.wait(1)
end
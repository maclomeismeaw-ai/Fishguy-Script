local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local money = player:WaitForChild("leaderstats"):WaitForChild("Money")
local troops = workspace:WaitForChild("Troops")
local remote = RS.NetworkingContainer.DataRemote
local currentWave = RS:WaitForChild("MatchData"):WaitForChild("CurrentWave")

local costs = {800,1500,3000,5000}

repeat
    task.wait()
until currentWave.Value == 1

task.wait(1)

local function waitMoney(amount)
    while money.Value < amount do
        money:GetPropertyChangedSignal("Value"):Wait()
    end
end

local function countUnits(name)
    local total = 0

    for _,v in ipairs(troops:GetChildren()) do
        if v.Name == name then
            total += 1
        end
    end

    return total
end

local function updateValues()
    local index = 0

    for _,v in ipairs(troops:GetChildren()) do
        if v.Name == "CameraSpider" then
            index += 1

            local val = v:FindFirstChild("Value") or Instance.new("IntValue")
            val.Name = "Value"
            val.Value = index
            val.Parent = v
        end
    end
end

local function getCameraByValue(num)
    for _,v in ipairs(troops:GetChildren()) do
        if v.Name == "CameraSpider" then
            local val = v:FindFirstChild("Value")

            if val and val.Value == num then
                return v
            end
        end
    end
end

local function getLatestSpider()
    updateValues()

    local highest = 0
    local found = nil

    for _,v in ipairs(troops:GetChildren()) do
        if v.Name == "CameraSpider" then
            local val = v:FindFirstChild("Value")

            if val and val.Value > highest then
                highest = val.Value
                found = v
            end
        end
    end

    return found
end

local function place(unitName, position, slot, cost)
    while true do
        waitMoney(cost)

        local before = countUnits(unitName)

        local args = {
            [1] = {
                [1] = {
                    [1] = "\226\129\130\22",
                    [2] = unitName,
                    [3] = position,
                    [4] = slot
                }
            }
        }

        remote:FireServer(unpack(args))

        local start = tick()

        repeat
            task.wait(0.3)

            if countUnits(unitName) > before then
                task.wait(0.5)
                return true
            end

        until tick() - start >= 3
    end
end

local function upgradeToLevel(unit,targetLevel,costTable)
    if not unit then return end

    while unit and unit.Parent do
        local level = unit:FindFirstChild("TroopLevel")

        if not level then
            task.wait(0.5)
            continue
        end

        if level.Value >= targetLevel then
            return
        end

        local nextCost = costTable[level.Value]

        if nextCost then
            waitMoney(nextCost)
        end

        local before = level.Value

        local args = {
            [1] = {
                [1] = {
                    [1] = "\226\129\130#",
                    [2] = unit
                }
            }
        }

        remote:FireServer(unpack(args))

        local start = tick()

        repeat
            task.wait(0.3)

            if not unit or not unit.Parent then
                return
            end

            level = unit:FindFirstChild("TroopLevel")

            if level and level.Value > before then
                break
            end

        until tick() - start >= 3
    end
end


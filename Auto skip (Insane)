local player = game:GetService("Players").LocalPlayer
local replicatedStorage = game:GetService("ReplicatedStorage")

local button = player:WaitForChild("PlayerGui")
    :WaitForChild("Match")
    :WaitForChild("TopFrame")
    :WaitForChild("AutoSkip")
    :WaitForChild("OnAndOff")

local currentWave = replicatedStorage:WaitForChild("MatchData"):WaitForChild("CurrentWave")

local function clickButton()
    for _, v in pairs(getconnections(button.Activated)) do
        v:Fire()
    end
end

local function isRed()
    local color = button.BackgroundColor3
    return color.R == 1 and color.G == 0 and color.B == 0
end

while true do
    local wave = currentWave.Value

    -- Wave 1 - 39 = ต้องไม่แดง
    if wave >= 1 and wave <= 39 then
        if isRed() then
            clickButton()
            task.wait(0.5)
        end

    -- Wave 40 = ต้องแดงค้างจนถึง 41
    elseif wave == 40 then
        if not isRed() then
            clickButton()
            task.wait(0.5)
        end

    -- Wave 41 - 50 = ต้องไม่แดง
    elseif wave >= 41 and wave <= 50 then
        if isRed() then
            clickButton()
            task.wait(0.5)
        end
    end

    task.wait(1)
end